{
	"schemaVersion": 1,
	"id": "${id}",
	"version": "${version}",
	"name": "${name}",
	"description": "Plays your own imported music during fights! Client-side, smooth fades, dynamic changes, very customizable.",
	"authors": [
		"Lemon553311"
	],

	"contact": {
		"homepage": "https://modrinth.com/mod/battle-music",
		"sources": "https://github.com/Lemon553311-dev/battlemusic",
		"issues": "https://github.com/Lemon553311-dev/battlemusic/issues",
		"Discords": "Lemon553311"
	},

	"license": "MIT",
	"icon": "assets/battlemusic/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"me.lemon553311.battlemusic.BattleMusicClient"
		],
		"modmenu": [
			"me.lemon553311.battlemusic.config.ModMenuIntegration"
		]
	},

	"depends": {
		"fabricloader": "${loader}",
		"minecraft": "${minecraft}",
		"java": "${java}",
		"${fabric_api_id}": "*"
	},

	"suggests": {
		"modmenu": "*",
		"cloth-config2": "*"
	}
}
